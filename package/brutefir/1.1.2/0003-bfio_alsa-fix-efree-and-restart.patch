+        as->restart = false;
+        if ((err = snd_pcm_start(as->handle)) < 0) {
+            fprintf(stderr, "ALSA I/O: Could not restart audio: %s.\n", snd_strerror(err));
+            errno = EPIPE;
+            return -1;
+        }
+    }
+
     if (as->isinterleaved) {
         frame_size = as->sample_size * as->open_channels;
         if (as->ismmap) {
