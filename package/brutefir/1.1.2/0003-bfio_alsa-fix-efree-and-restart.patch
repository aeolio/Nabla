@@ -550,7 +550,8 @@
         as->channel_selection = malloc(used_channels * sizeof(int));
         memcpy(as->channel_selection, channel_selection, used_channels * sizeof(int));
     }
-    free(settings->device);
+    if (settings->device != NULL)
+        free(settings->device);
     free(settings);
     return pollfd.fd;
 }
@@ -732,6 +733,16 @@
